# Job Search Agent — Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# LLM — Google Gemini (free at aistudio.google.com)
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ============================================================================
# Applicant Details
# ============================================================================
APPLICANT_NAME=Your Full Name
APPLICANT_EMAIL=your.email@gmail.com
GMAIL_SENDER=your.email@gmail.com
DIGEST_RECIPIENT=your.email@gmail.com
APPLICANT_PHONE=+1-555-123-4567
APPLICANT_LINKEDIN=https://linkedin.com/in/yourprofile

# ============================================================================
# Job Search Preferences
# ============================================================================
TARGET_ROLES=Senior Program Manager, Product Manager, Strategy Manager
MIN_SALARY=120000

# ============================================================================
# Gmail Configuration (for sending digest emails)
# Get App Password: myaccount.google.com → Security → App Passwords
# ============================================================================
GMAIL_APP_PASSWORD=your_16_char_app_password

# ============================================================================
# Adzuna Job Board API (optional)
# Get credentials: www.adzuna.com/api/v1/developer
# ============================================================================
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ============================================================================
# Job Board URLs (comma-separated)
# ============================================================================
JOB_BOARD_URLS=https://www.linkedin.com/jobs/search/?keywords=,https://www.indeed.com/jobs?q=

# ============================================================================
# Scraping Configuration
# ============================================================================
LINKEDIN_TIMEOUT_SECONDS=90
INDEED_TIMEOUT_SECONDS=60
SELENIUM_HEADLESS=true

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
